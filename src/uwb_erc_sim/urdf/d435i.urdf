<?xml version="1.0"?>
<robot name="standalone_camera">
  <link name="base_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="realsense_d435i" type="camera">
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>1.50098</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.1</near><far>100</far></clip>
      </camera>
      <topic>camera/image_raw</topic>
      <gz_frame_id>camera_link</gz_frame_id>
    </sensor>

    <light name="spotlight" type="spot">
      <pose>0.1 0 0 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>1 1 1 1</specular>
      <attenuation><range>20</range><constant>0.5</constant><linear>0.01</linear></attenuation>
      <direction>1 0 0</direction>
      <spot><inner_angle>0.1</inner_angle><outer_angle>0.5</outer_angle></spot>
    </light>
  </gazebo>
</robot>
